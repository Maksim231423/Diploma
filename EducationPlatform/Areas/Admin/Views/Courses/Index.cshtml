@model EducationPlatform.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Панель адміністратора";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
        ✅ @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
        ❌ @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<h2 class="text-white mb-4">Огляд платформи</h2>

<div class="row mb-5">
    <div class="col-md-3 mb-3">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body">
                <h6 class="text-secondary text-uppercase mb-2">Студентів</h6>
                <h3 class="text-white fw-bold mb-0">@Model.TotalStudents</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body">
                <h6 class="text-secondary text-uppercase mb-2">Активних курсів</h6>
                <h3 class="text-white fw-bold mb-0">@Model.ActiveCourses</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-dark border-secondary shadow-sm @(Model.NewHomeworks > 0 ? "border-start border-warning border-4" : "")">
            <div class="card-body">
                <h6 class="text-secondary text-uppercase mb-2">Нових завдань</h6>
                <h3 class="text-white fw-bold mb-0">@Model.NewHomeworks</h3>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-dark border-secondary shadow-sm">
            <div class="card-body">
                <h6 class="text-secondary text-uppercase mb-2">Дохід за місяць</h6>
                <h3 class="text-success fw-bold mb-0">₴ @Model.MonthlyIncome.ToString("N0")</h3>
            </div>
        </div>
    </div>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-header border-secondary bg-dark py-3">
        <h5 class="text-white mb-0">📧 Швидка Email розсилка</h5>
    </div>
    <div class="card-body p-4">
        <form asp-action="SendNewsletter" method="post">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label text-secondary">Отримувачі</label>
                    <select name="targetAudience" class="form-select bg-dark text-white border-secondary" required>
                        <option value="all">Всі зареєстровані студенти</option>
                        <option value="active">Лише ті, хто має хоча б один курс</option>
                        <optgroup label="Студенти конкретного курсу">
                            @if (ViewBag.Courses != null)
                            {
                                foreach (var course in ViewBag.Courses)
                                {
                                    <option value="course_@course.Id">Курс: @course.Title</option>
                                }
                            }
                        </optgroup>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label text-secondary">Тема листа</label>
                    <input type="text" name="subject" class="form-control bg-dark text-white border-secondary" placeholder="Наприклад: Оновлення програми курсу" required>
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label text-secondary">Текст повідомлення</label>
                <textarea name="message" class="form-control bg-dark text-white border-secondary" rows="4" placeholder="Введіть текст листа..." required></textarea>
            </div>
            <button type="submit" class="btn btn-primary px-4 fw-bold" onclick="return confirm('Ви впевнені, що хочете запустити цю розсилку?');">Відправити розсилку 🚀</button>
        </form>
    </div>
</div>