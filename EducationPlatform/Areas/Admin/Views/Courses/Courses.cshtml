@{
    ViewData["Title"] = "Курси та Уроки";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="text-white mb-0">📚 Управління курсами</h2>
    <button class="btn btn-primary fw-bold px-4">+ Створити курс</button>
</div>

<div class="card bg-dark border-secondary shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead class="table-active border-secondary">
                    <tr>
                        <th class="py-3 px-4">Назва курсу</th>
                        <th class="py-3 text-center">Уроків</th>
                        <th class="py-3">Теги</th>
                        <th class="py-3">Ціна</th>
                        <th class="py-3 text-end px-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="px-4 py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary rounded me-3" style="width: 50px; height: 35px; background-image: url('https://via.placeholder.com/50x35/0d6efd/ffffff?text=C%23'); background-position: center; background-size: cover;"></div>
                                <div class="text-white fw-bold">Основи C# та .NET Core</div>
                            </div>
                        </td>
                        <td class="text-center text-info fw-bold">12</td>
                        <td>
                            <span class="badge border border-secondary text-secondary me-1">#C#</span>
                            <span class="badge border border-secondary text-secondary">#.NET</span>
                        </td>
                        <td class="text-success fw-bold">1500 ₴</td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-outline-info me-1" title="Редагувати">✏️</button>
                            <button class="btn btn-sm btn-outline-danger" title="Видалити">🗑️</button>
                        </td>
                    </tr>
                    <tr>
                        <td class="px-4 py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-secondary rounded me-3" style="width: 50px; height: 35px; background-image: url('https://via.placeholder.com/50x35/ffc107/000000?text=SQL'); background-position: center; background-size: cover;"></div>
                                <div class="text-white fw-bold">Проектування Баз Даних SQL</div>
                            </div>
                        </td>
                        <td class="text-center text-info fw-bold">8</td>
                        <td>
                            <span class="badge border border-secondary text-secondary me-1">#SQL</span>
                            <span class="badge border border-secondary text-secondary">#БД</span>
                        </td>
                        <td class="text-success fw-bold">1200 ₴</td>
                        <td class="text-end px-4">
                            <button class="btn btn-sm btn-outline-info me-1" title="Редагувати">✏️</button>
                            <button class="btn btn-sm btn-outline-danger" title="Видалити">🗑️</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>