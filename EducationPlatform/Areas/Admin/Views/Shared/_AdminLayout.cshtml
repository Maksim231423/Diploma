@using EducationPlatform.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext _context

@{
    // Наслідуємо глобальну шапку і підключення стилів сайту
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Визначаємо, на якому контролері і сторінці ми зараз знаходимося
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();

    // ДОДАНО: Рахуємо неперевірені домашки в реальному часі
    int newHomeworksCount = await _context.HomeworkSubmissions.CountAsync(h => !h.IsChecked);

}

<div class="container-fluid mt-4 mb-5">
    <div class="row">

        <div class="col-md-3 col-lg-2 mb-4">
            <div class="card bg-dark border-secondary shadow-sm h-100">
                <div class="card-body p-3">
                    <h5 class="text-white mb-4 mt-2 px-2 fw-bold">⚙️ Admin Panel</h5>
                    <div class="list-group list-group-flush rounded">

                        <a asp-area="Admin" asp-controller="Courses" asp-action="Index"
                           class="list-group-item list-group-item-action border-secondary @(controller == "Courses" && action == "Index" ? "bg-primary text-white fw-bold" : "bg-dark text-light")">
                            📊 Дашборд
                        </a>

                        <a asp-area="Admin" asp-controller="Courses" asp-action="Courses"
                           class="list-group-item list-group-item-action border-secondary @(controller == "Courses" && action == "Courses" ? "bg-primary text-white fw-bold" : "bg-dark text-light")">
                            📚 Курси та Уроки
                        </a>

                        <a asp-area="Admin" asp-controller="Courses" asp-action="Homeworks"
                           class="list-group-item list-group-item-action border-secondary d-flex justify-content-between align-items-center @(controller == "Courses" && action == "Homeworks" ? "bg-primary text-white fw-bold" : "bg-dark text-light")">
                            📝 Домашні завдання

                            @if (newHomeworksCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill shadow-sm">@newHomeworksCount</span>
                            }
                        </a>

                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                               class="list-group-item list-group-item-action border-secondary @(controller == "Users" && action == "Index" ? "bg-primary text-white fw-bold" : "bg-dark text-light")">
                                👥 Керування персоналом
                            </a>
                        }

                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-9 col-lg-10">
            @RenderBody()
        </div>
    </div>
</div>
@await RenderSectionAsync("Scripts", required: false)