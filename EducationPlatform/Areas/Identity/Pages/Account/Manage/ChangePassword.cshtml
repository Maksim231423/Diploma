@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Зміна пароля";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <div class="card bg-dark text-white border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="mb-0">🔑 Відновлення та зміна пароля</h5>
            </div>
            <div class="card-body p-4">
                <form id="change-password-form" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="row align-items-end mb-4">
                        <div class="col-md-8">
                            <label class="form-label text-secondary">Ваш Email (для отримання коду)</label>
                            <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" readonly />
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <button type="submit"
                                    asp-page-handler="SendCode"
                                    formnovalidate
                                    class="btn btn-outline-info w-100">
                                Відправити код
                            </button>
                        </div>
                    </div>

                    <div class="mb-4 w-50">
                        <label asp-for="Input.Code" class="form-label text-secondary">Код підтвердження</label>
                        <input asp-for="Input.Code" class="form-control bg-dark text-white border-secondary text-center fs-5" placeholder="123456" />
                        <span asp-validation-for="Input.Code" class="text-danger"></span>
                    </div>

                    <div class="mb-5 w-75">
                        <label asp-for="Input.NewPassword" class="form-label text-secondary">Новий пароль</label>

                        <div class="input-group">
                            <input name="Input.NewPassword"
                                   id="passwordInput"
                                   type="password"
                                   class="form-control bg-dark text-white border-secondary"
                                   placeholder="Введіть новий пароль"
                                   value="@(Model.Input?.NewPassword)" />

                            <button class="btn btn-outline-secondary border-secondary" type="button" onclick="togglePassword('passwordInput')">
                                👁️
                            </button>
                        </div>

                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" asp-page-handler="ChangePassword" class="btn btn-primary px-4">Змінити пароль</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(fieldId) {
            var input = document.getElementById(fieldId);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>
}