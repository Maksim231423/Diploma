@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Зміна пароля";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-8">
        <div class="card bg-dark text-white border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="mb-0">🔑 Відновлення та зміна пароля</h5>
            </div>
            <div class="card-body p-4">
                <form id="change-password-form" method="post">

                    <div class="row align-items-end mb-4">
                        <div class="col-md-8">
                            <label class="form-label text-secondary">Ваш Email</label>
                            <input type="email" class="form-control bg-dark text-white border-secondary" placeholder="name@example.com" />
                        </div>
                        <div class="col-md-4 mt-3 mt-md-0">
                            <button type="button" class="btn btn-outline-info w-100">Відправити код</button>
                        </div>
                    </div>

                    <div class="mb-4 w-50">
                        <label class="form-label text-secondary">Код (відправлений на email)</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="123456" />
                    </div>

                    <div class="mb-5 w-75">
                        <label asp-for="Input.NewPassword" class="form-label text-secondary">Новий пароль</label>
                        <input asp-for="Input.NewPassword" class="form-control bg-dark text-white border-secondary" placeholder="Введіть новий пароль" />
                        <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary px-4">Змінити пароль</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}