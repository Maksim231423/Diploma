@page
@model IndexModel
@{
    ViewData["Title"] = "Налаштування профілю";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-5 mb-4">
        <div class="card bg-dark text-white border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="mb-0">Мої дані</h5>
            </div>
            <div class="card-body p-4">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>


                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control bg-dark text-white border-secondary" disabled />
                        <label asp-for="Username" class="text-secondary">Ім'я користувача</label>
                    </div>
                    <button id="update-profile-button" type="submit" class="btn btn-primary w-100">Зберегти зміни</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7 mb-4">
        <div class="card bg-dark border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="text-white mb-0">🎓 Мої курси</h5>
            </div>
            <div class="card-body p-4">

                <div class="border border-secondary rounded p-3 mb-3 d-flex align-items-center bg-dark">
                    <div class="bg-primary text-white rounded p-3 me-3 d-flex justify-content-center align-items-center" style="width: 60px; height: 60px;">
                        <span class="fs-4 fw-bold">C#</span>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="text-white mb-1">Основи C# та .NET Core</h6>
                        <div class="progress bg-secondary mt-2" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 75%;" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-white-50 mt-1 d-block">Пройдено: 75% (15/20 уроків)</small>
                    </div>
                    <button class="btn btn-sm btn-outline-light ms-3">Продовжити</button>
                </div>

                <div class="border border-secondary rounded p-3 d-flex align-items-center bg-dark">
                    <div class="bg-warning text-dark rounded p-3 me-3 d-flex justify-content-center align-items-center" style="width: 60px; height: 60px;">
                        <span class="fs-4 fw-bold">DB</span>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="text-white mb-1">Проектування Баз Даних SQL</h6>
                        <div class="progress bg-secondary mt-2" style="height: 6px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: 10%;" aria-valuenow="10" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <small class="text-white-50 mt-1 d-block">Пройдено: 10% (1/10 уроків)</small>
                    </div>
                    <button class="btn btn-sm btn-outline-light ms-3">Почати</button>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}