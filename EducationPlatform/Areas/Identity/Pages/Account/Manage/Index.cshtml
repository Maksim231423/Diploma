@page
@model IndexModel
@{
    ViewData["Title"] = "Налаштування профілю";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-md-5 mb-4">
        <div class="card bg-dark text-white border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="mb-0">Мої дані</h5>
            </div>
            <div class="card-body p-4">
                <form id="profile-form" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Username" class="form-control bg-dark text-white border-secondary" />
                        <label asp-for="Input.Username" class="text-secondary">Ім'я користувача</label>
                        <span asp-validation-for="Input.Username" class="text-danger"></span>
                    </div>

                    <button id="update-profile-button" type="submit" class="btn btn-primary w-100 fw-bold">Зберегти зміни</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-7 mb-4">
        <div class="card bg-dark border-secondary shadow-sm h-100">
            <div class="card-header border-secondary">
                <h5 class="text-white mb-0">🎓 Мої курси</h5>
            </div>
            <div class="card-body p-4">

                @if (Model.MyCourses.Count == 0)
                {
                    <div class="text-center text-secondary py-4">
                        <span class="fs-1 d-block mb-2">📚</span>
                        Ви ще не придбали жодного курсу.<br />
                        <a href="/Home/Courses" class="btn btn-outline-info mt-3">Перейти до каталогу</a>
                    </div>
                }
                else
                {
                    @foreach (var course in Model.MyCourses)
                    {
                        <div class="border border-secondary rounded p-3 mb-3 d-flex align-items-center bg-dark">
                            <div class="me-3 rounded overflow-hidden shadow-sm" style="width: 80px; height: 60px;">
                                <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "https://via.placeholder.com/80x60?text=Course" : course.ImageUrl)"
                                     alt="Course" style="width: 100%; height: 100%; object-fit: cover;">
                            </div>

                            <div class="flex-grow-1">
                                <h6 class="text-white mb-1">@course.Title</h6>

                                @if (course.TotalTasks > 0)
                                {
                                    <div class="progress bg-secondary mt-2" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: @course.ProgressPercentage%;" aria-valuenow="@course.ProgressPercentage" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small class="text-white-50 mt-1 d-block">
                                        Практика: @course.ProgressPercentage% (@course.SubmittedTasks / @course.TotalTasks завдань).
                                        <span class="text-info">Перевірено вчителем: @course.CheckedTasks</span>
                                    </small>
                                }
                                else
                                {
                                    <small class="text-white-50 mt-2 d-block">У цьому курсі немає практичних завдань.</small>
                                }
                            </div>

                            <a asp-area="" asp-controller="Home" asp-action="CourseDetails" asp-route-id="@course.CourseId" class="btn btn-sm btn-outline-light ms-3">
                                Продовжити
                            </a>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}