@page
@model LoginModel

@{
    ViewData["Title"] = "Вхід";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml"; //Наш додатковий Layout
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-white shadow-lg border-secondary">
                <div class="card-header text-center border-secondary">
                    <h2>🔐 Вхід</h2>
                </div>
                <div class="card-body p-4">
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary">Email адреса</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="input-group mb-3">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.Password" class="form-control bg-dark text-white border-secondary" id="passwordInput" autocomplete="current-password" aria-required="true" placeholder="Пароль" />
                                <label asp-for="Input.Password" class="text-secondary">Пароль</label>
                            </div>
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('passwordInput')">
                                👁️
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger d-block mb-3"></span>

                        <div class="form-check mb-3">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">
                                Запам'ятати мене
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="btn btn-lg btn-primary w-100">Увійти</button>
                    </form>

                    <div class="mt-3 text-center">
                        <p>
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-info text-decoration-none">Ще немає акаунту? Зареєструватись</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(fieldId) {
            var input = document.getElementById(fieldId);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>
}