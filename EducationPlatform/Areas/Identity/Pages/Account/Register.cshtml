@page
@model RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card bg-dark text-white shadow-lg border-secondary">
                <div class="card-header text-center border-secondary">
                    <h2>🚀 Реєстрація</h2>
                </div>
                <div class="card-body p-4">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.UserName" class="form-control bg-dark text-white border-secondary" aria-required="true" placeholder="Maksym" />
                            <label asp-for="Input.UserName" class="text-secondary">Ваше ім'я</label>
                            <span asp-validation-for="Input.UserName" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control bg-dark text-white border-secondary" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="text-secondary">Email адреса</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="input-group mb-3">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.Password" class="form-control bg-dark text-white border-secondary" id="regPass" autocomplete="new-password" aria-required="true" placeholder="Пароль" />
                                <label asp-for="Input.Password" class="text-secondary">Пароль</label>
                            </div>
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('regPass')">
                                👁️
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger d-block mb-3"></span>

                        <div class="input-group mb-3">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.ConfirmPassword" class="form-control bg-dark text-white border-secondary" id="confPass" autocomplete="new-password" aria-required="true" placeholder="Повторіть пароль" />
                                <label asp-for="Input.ConfirmPassword" class="text-secondary">Повторіть пароль</label>
                            </div>
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('confPass')">
                                👁️
                            </button>
                        </div>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger d-block mb-3"></span>

                        <button id="registerSubmit" type="submit" class="btn btn-lg btn-success w-100">Створити акаунт</button>
                    </form>

                    <div class="mt-3 text-center">
                        <p>
                            Вже є акаунт? <a asp-page="./Login" class="text-info text-decoration-none">Увійти</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePassword(fieldId) {
            var input = document.getElementById(fieldId);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>
}