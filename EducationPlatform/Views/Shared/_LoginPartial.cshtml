@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="auth-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-white" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                Привіт, @User.Identity?.Name!
            </a>
        </li>
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="btn-custom btn-logout">Вийти</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn-custom btn-register" asp-area="Identity" asp-page="/Account/Register">Регістрація</a>
        </li>
        <li class="nav-item">
            <a class="btn-custom btn-login" asp-area="Identity" asp-page="/Account/Login">Вхід</a>
        </li>
    }
</ul>