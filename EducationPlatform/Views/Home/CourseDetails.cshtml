@model EducationPlatform.Models.Course

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    @if (TempData["AccessDenied"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm border-warning" role="alert">
            <span class="fs-5 me-2">⚠️</span>
            <strong>Обмежений доступ!</strong> @TempData["AccessDenied"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="row">
        <div class="col-md-5 mb-4">
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://via.placeholder.com/600x400?text=ITskill+Course" : Model.ImageUrl)"
                 class="img-fluid rounded shadow-lg" alt="@Model.Title" style="width: 100%; object-fit: cover;">
        </div>

        <div class="col-md-7">
            <h1 class="display-4 fw-bold text-white">@Model.Title</h1>
            <div class="badge bg-warning text-dark fs-6 mb-3">C# / .NET</div>

            <p class="lead text-white-50">@Model.Description</p>

            <h2 class="text-primary my-4">@Model.Price.ToString("N0") ₴</h2>

            @if (ViewBag.IsPurchased == true)
            {
                <div class="alert alert-success rounded-pill px-5 py-3 fw-bold shadow text-center">
                    ✅ Ви вже придбали цей курс
                </div>
            }
            else
            {
                <form asp-controller="Payment" asp-action="Checkout" method="post">
                    <input type="hidden" name="courseId" value="@Model.Id" />
                    <input type="hidden" name="courseTitle" value="@Model.Title" />
                    <input type="hidden" name="price" value="@Model.Price.ToString("N0")" />

                    <button type="submit" class="btn btn-lg btn-danger px-5 py-3 rounded-pill fw-bold shadow w-100">
                        🚀 Почати навчання за @Model.Price.ToString("N0") ₴
                    </button>
                </form>
            }
        </div>
    </div>

    <hr class="my-5 border-secondary" />

    <div class="row">
        <div class="col-12">
            <h3 class="text-white mb-4">📚 Програма курсу</h3>

            @if (Model.Lessons.Count == 0)
            {
                <div class="alert alert-dark text-white-50">
                    Уроки ще додаються...
                </div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var lesson in Model.Lessons.OrderBy(l => l.OrderNumber))
                    {
                        <a asp-controller="Home" asp-action="Lesson" asp-route-id="@lesson.Id" class="list-group-item list-group-item-action bg-dark text-white border-secondary d-flex justify-content-between align-items-center p-3">
                            <div>
                                <span class="fw-bold text-warning me-3">Урок #@lesson.OrderNumber</span>
                                <span>@lesson.Title</span>
                            </div>
                            <span class="badge bg-success">▶ Play</span>
                        </a>
                    }
                </div>
            }
        </div>
    </div>

    <hr class="my-5 border-secondary" />

    <div class="row mb-5">
        <div class="col-12">
            <h3 class="text-white mb-4">💬 Коментарі (@Model.Comments.Count)</h3>

            @if (User.Identity.IsAuthenticated)
            {
                // ДОДАНО: Перевіряємо статус покупки
                if (ViewBag.IsPurchased == true)
                {
                    <div class="card bg-dark border-secondary mb-5 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="text-white mb-3">Залишити коментар</h5>

                            <form asp-controller="Home" asp-action="AddComment" method="post">
                                <input type="hidden" name="courseId" value="@Model.Id" />

                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label text-secondary">Ваше ім'я</label>
                                        <input type="text" class="form-control bg-dark text-white-50 border-secondary" value="@User.Identity.Name" disabled readonly>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-secondary">Ваш коментар</label>
                                    <textarea name="text" class="form-control bg-dark text-white border-secondary" rows="3" placeholder="Напишіть свої враження від курсу..." required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary px-4">Відправити</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning bg-dark text-warning border-warning mb-5 d-flex align-items-center shadow-sm">
                        <span class="fs-4 me-3">📝</span>
                        <div>
                            Тільки студенти, які придбали цей курс, можуть залишати коментарі та ділитися враженнями.
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary bg-dark text-white border-secondary mb-5 d-flex align-items-center shadow-sm">
                    <span class="fs-4 me-3">🔒</span>
                    <div>
                        Щоб залишити коментар, будь ласка,
                        <a href="/Identity/Account/Login" class="text-info fw-bold text-decoration-none">увійдіть</a> або
                        <a href="/Identity/Account/Register" class="text-info fw-bold text-decoration-none">зареєструйтесь</a>.
                    </div>
                </div>
            }
            <div class="comment-list">
                @if (Model.Comments != null && Model.Comments.Any())
                {
                    // Сортуємо так, щоб найновіші були зверху
                    @foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                    {
                        <div class="card bg-dark border-secondary mb-3 shadow-sm">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong class="text-info fs-5">@(comment.User?.UserName ?? "Користувач")</strong>
                                    <small class="text-secondary">@comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                                </div>
                                <p class="text-light mb-0" style="line-height: 1.6;">
                                    @comment.Text
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-secondary fs-5 text-center my-4">Коментарів поки немає. Будьте першим!</p>
                }
            </div>
        </div>
    </div>
</div>