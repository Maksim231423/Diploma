@model List<EducationPlatform.Models.Course>
@{
    ViewData["Title"] = "Каталог курсів";

    // 1. ОГОЛОШУЄМО ЗМІННІ НА САМОМУ ВЕРХУ, щоб вся сторінка їх бачила
    var currentTags = ViewBag.SelectedTags as List<string> ?? new List<string>();
    bool hasSearchOrTags = !string.IsNullOrEmpty(ViewBag.SearchQuery) || currentTags.Any();
}

<div class="container-fluid bg-dark text-white py-5 mb-5 border-bottom border-secondary shadow-sm">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-4">Каталог <span class="text-primary">курсів</span></h1>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <form method="get" asp-action="Courses" class="input-group input-group-lg shadow-sm">

                    @if (currentTags.Any())
                    {
                        foreach (var tag in currentTags)
                        {
                            <input type="hidden" name="selectedTags" value="@tag" />
                        }
                    }

                    <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="form-control bg-dark text-white border-secondary" placeholder="Який курс ви шукаєте? (напр. C# або SQL)">

                    <button class="btn btn-primary px-4" type="submit">🔍 Знайти</button>

                    @if (hasSearchOrTags)
                    {
                        <a asp-action="Courses" class="btn btn-outline-danger px-3">❌ Скинути</a>
                    }
                </form>
            </div>
        </div>

        <div class="mt-4">
            <span class="text-secondary me-3">Фільтр по тегам:</span>

            @if (ViewBag.AllTags != null)
            {
                foreach (var t in ViewBag.AllTags as List<string>)
                {
                    // Перевіряємо, чи є цей тег у списку обраних (тепер currentTags доступна!)
                    bool isSelected = currentTags.Contains(t);
                    var bgClass = isSelected ? "bg-primary text-white" : "bg-secondary text-white";

                    // Створюємо новий список тегів для посилання
                    var newTagsList = new List<string>(currentTags);
                    if (isSelected) newTagsList.Remove(t);
                    else newTagsList.Add(t);

                    <a asp-action="Courses"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-selectedTags="@string.Join(",", newTagsList)"
                       class="badge @bgClass me-2 p-2 border border-secondary text-decoration-none" style="cursor: pointer;">
                        #@(isSelected ? "✓ " : "")@t
                    </a>
                }
            }
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var course in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card bg-dark text-white border-secondary h-100 shadow-sm course-card">
                        <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "https://via.placeholder.com/600x400/343a40/ffffff?text=Курс" : course.ImageUrl)"
                             class="card-img-top border-bottom border-secondary" alt="@course.Title" style="height: 200px; object-fit: cover;">

                        <div class="card-body d-flex flex-column">
                            <div class="mb-3">
                                @if (course.Tags != null && course.Tags.Any())
                                {
                                    @foreach (var cTag in course.Tags)
                                    {
                                        <span class="badge bg-warning text-dark me-1">@cTag.Name</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary text-light me-1">Без тегів</span>
                                }
                            </div>
                            <h5 class="card-title fw-bold">@course.Title</h5>
                            <p class="card-text text-secondary mb-4 flex-grow-1">
                                @(course.Description?.Length > 80 ? course.Description.Substring(0, 80) + "..." : course.Description)
                            </p>

                            <div class="mt-auto pt-3 border-top border-secondary text-center">
                                <h4 class="text-primary fw-bold mb-3">@course.Price.ToString("N0") ₴</h4>
                                <a asp-controller="Home" asp-action="CourseDetails" asp-route-id="@course.Id" class="btn btn-outline-light w-100 rounded-pill">
                                    Детальніше
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-secondary fs-5">Курсів поки що немає. Загляньте пізніше!</p>
            </div>
        }
    </div>
</div>

<style>
    .course-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.5) !important;
            border-color: #0dcaf0 !important;
        }

    .badge.bg-secondary:hover {
        background-color: #0dcaf0 !important;
        color: #000 !important;
    }
</style>