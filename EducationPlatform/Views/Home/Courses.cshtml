@model List<EducationPlatform.Models.Course>
@{
    ViewData["Title"] = "Каталог курсів";
}

<div class="container-fluid bg-dark text-white py-5 mb-5 border-bottom border-secondary shadow-sm">
    <div class="container text-center">
        <h1 class="display-5 fw-bold mb-4">Каталог <span class="text-primary">курсів</span></h1>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="input-group input-group-lg shadow-sm">
                    <input type="text" class="form-control bg-dark text-white border-secondary" placeholder="Який курс ви шукаєте? (напр. C# або SQL)">
                    <button class="btn btn-primary px-5" type="button">🔍 Знайти</button>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <span class="text-secondary me-3">Популярні теги:</span>
            <span class="badge bg-secondary me-2 p-2 border border-secondary" style="cursor: pointer;">#C#</span>
            <span class="badge bg-secondary me-2 p-2 border border-secondary" style="cursor: pointer;">#.NET Core</span>
            <span class="badge bg-secondary me-2 p-2 border border-secondary" style="cursor: pointer;">#Бази Даних</span>
            <span class="badge bg-secondary p-2 border border-secondary" style="cursor: pointer;">#Веб-розробка</span>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var course in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card bg-dark text-white border-secondary h-100 shadow-sm course-card">
                        <img src="@(string.IsNullOrEmpty(course.ImageUrl) ? "https://via.placeholder.com/600x400/343a40/ffffff?text=Курс" : course.ImageUrl)"
                             class="card-img-top border-bottom border-secondary" alt="@course.Title" style="height: 200px; object-fit: cover;">

                        <div class="card-body d-flex flex-column">
                            <div class="badge bg-warning text-dark w-25 mb-3">C# / .NET</div>
                            <h5 class="card-title fw-bold">@course.Title</h5>
                            <p class="card-text text-secondary mb-4 flex-grow-1">
                                @(course.Description?.Length > 80 ? course.Description.Substring(0, 80) + "..." : course.Description)
                            </p>

                            <div class="mt-auto pt-3 border-top border-secondary text-center">
                                <h4 class="text-primary fw-bold mb-3">@course.Price ₴</h4>
                                <a asp-controller="Home" asp-action="CourseDetails" asp-route-id="@course.Id" class="btn btn-outline-light w-100 rounded-pill">
                                    Детальніше
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-secondary fs-5">Курсів поки що немає. Загляньте пізніше!</p>
            </div>
        }
    </div>
</div>

<style>
    .course-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .course-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.5) !important;
            border-color: #0dcaf0 !important;
        }

    .badge.bg-secondary:hover {
        background-color: #0dcaf0 !important;
        color: #000 !important;
    }
</style>