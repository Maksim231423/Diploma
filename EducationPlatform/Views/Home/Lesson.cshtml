@model EducationPlatform.Models.Lesson

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-secondary text-decoration-none">Головна</a></li>
            <li class="breadcrumb-item"><a asp-action="CourseDetails" asp-route-id="@Model.CourseId" class="text-secondary text-decoration-none">@Model.Course.Title</a></li>
            <li class="breadcrumb-item active text-white" aria-current="page">@Model.Title</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <div class="ratio ratio-16x9 shadow-lg border border-secondary rounded overflow-hidden">
                <iframe src="@Model.VideoUrl"
                        title="YouTube video player"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen>
                </iframe>
            </div>

            <div class="mt-4">
                <h2 class="text-white">@Model.Title</h2>
                <p class="text-white-50 mt-3">@Model.Content</p>
            </div>

            <div class="d-flex justify-content-between mt-5">
                <button class="btn btn-outline-secondary">← Попередній урок</button>
                <button class="btn btn-primary">Наступний урок →</button>
            </div>
        </div>

        <div class="col-lg-4 mt-4 mt-lg-0">
            <div class="card bg-dark border-secondary">
                <div class="card-header border-secondary text-white fw-bold">
                    Зміст курсу
                </div>
                <div class="list-group list-group-flush">
                    <div class="list-group-item bg-dark text-white border-secondary">
                        <small class="text-muted">Поточний урок:</small><br>
                        @Model.Title
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4">
                <i class="bi bi-code-slash"></i> Тут буде редактор коду
            </div>
        </div>
    </div>
</div>