@model EducationPlatform.Models.Lesson
@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid bg-dark text-white py-4 border-bottom border-secondary mb-4">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="#" class="text-info text-decoration-none">Мої курси</a></li>
                <li class="breadcrumb-item"><a href="#" class="text-info text-decoration-none">Основи C# та .NET Core</a></li>
                <li class="breadcrumb-item active text-secondary" aria-current="page">Урок 1</li>
            </ol>
        </nav>
        <h2 class="fw-bold">@Model.Title</h2>
    </div>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">

        <div class="col-lg-10">

            <div class="ratio ratio-16x9 bg-black rounded shadow-lg mb-4 border border-secondary overflow-hidden">
                @if (!string.IsNullOrEmpty(Model.VideoUrl))
                {
                    <video controls controlsList="nodownload" class="w-100 h-100" style="object-fit: cover; background-color: #000;">
                        <source src="@Model.VideoUrl" type="video/mp4">
                        Ваш браузер не підтримує відтворення відео.
                    </video>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-center text-secondary">
                        <div>
                            <span class="display-1 d-block mb-3 text-white opacity-75">▶</span>
                            <h4 class="text-white-50">Відео для цього уроку ще не додано</h4>
                        </div>
                    </div>
                }
            </div>

            <div class="card bg-dark text-white border-secondary shadow-sm mb-5">
                <div class="card-body p-4 p-md-5">
                    <h2 class="fw-bold">@Model.Title</h2>
                    <p class="text-light fs-5" style="line-height: 1.7;">
                        @Model.Content
                    </p>
                    @if (!string.IsNullOrWhiteSpace(Model.LearningObjectives))
                    {
                        <h5 class="mt-4 mb-3 text-info">Що ви навчитеся:</h5>
                        <ul class="text-secondary fs-5" style="line-height: 1.8;">

                            @* C# код, який розбиває текст на масив рядків по натисканню Enter (\n) *@
                            @foreach (var objective in Model.LearningObjectives.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <li>@objective</li>
                            }

                        </ul>
                    }
                </div>
            </div>

            <hr class="border-secondary my-5" />

            <div class="row mt-5 justify-content-center">
                <div class="col-md-8 mb-4">
                    <div class="card bg-dark border-secondary shadow-sm">
                        <div class="card-body p-4 p-md-5">
                            <h5 class="text-white mb-3">🎯 Практичне завдання</h5>
                            <p class="text-secondary mb-4 fs-5">
                                Напишіть просту консольну програму, яка запитує ім'я користувача та виводить привітання. Завантажте код на свій GitHub та надішліть посилання.
                            </p>
                            <form>
                                <div class="mb-3">
                                    <input type="url" class="form-control bg-dark text-white border-secondary py-2" placeholder="Вставте посилання на GitHub або Google Диск..." required>
                                </div>
                                <div class="text-end">
                                    <button type="submit" class="btn btn-outline-info px-4 fw-bold">Відправити</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4 mb-5 pb-5">
                <a asp-controller="Home" asp-action="CourseDetails" asp-route-id="@Model.CourseId" class="btn btn-outline-secondary px-4 py-2">
                    ← Повернутися до програми
                </a>
                <button class="btn btn-primary px-4 py-2">Наступний урок →</button>
            </div>

        </div>
    </div>
</div>