@{
    ViewData["Title"] = "Про нас";
}

<div class="container py-5 mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="text-center mb-5">
                <h1 class="display-4 fw-bold text-white mb-3">Хто ми <span class="text-primary">такі?</span></h1>
                <div class="bg-primary mx-auto" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>

            <div class="card bg-dark text-white border-secondary shadow-lg">
                <div class="card-body p-5 text-center">

                    <div class="mb-4">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle shadow" style="width: 80px; height: 80px;">
                            <span class="fs-1">🚀</span>
                        </div>
                    </div>

                    <h3 class="fw-bold mb-4">Твій провідник у світ IT</h3>

                    <p class="lead text-light mb-4" style="line-height: 1.8;">
                        <strong>ITskill</strong> — це сучасний простір для тих, хто прагне розвиватися та будувати успішну кар'єру.
                        Наша місія — зробити якісну технічну освіту доступною, практичною та максимально цікавою.
                    </p>

                    <p class="text-secondary mb-5" style="line-height: 1.7;">
                        Ми об'єднуємо досвідчених менторів та амбітних студентів, пропонуючи курси, що відповідають реальним вимогам ринку праці.
                        Замість нудної сухої теорії ви отримуєте максимум практики, розбір реальних кейсів та підтримку на кожному етапі навчання.
                        Здобувайте затребувані навички та робіть впевнений крок назустріч професії своєї мрії разом з нами!
                    </p>

                    <div class="row text-center pt-4 border-top border-secondary">
                        <div class="col-4">
                            <h3 class="text-primary fw-bold mb-0">15+</h3>
                            <span class="text-secondary small">Курсів</span>
                        </div>
                        <div class="col-4">
                            <h3 class="text-primary fw-bold mb-0">100%</h3>
                            <span class="text-secondary small">Практики</span>
                        </div>
                        <div class="col-4">
                            <h3 class="text-primary fw-bold mb-0">24/7</h3>
                            <span class="text-secondary small">Підтримка</span>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>